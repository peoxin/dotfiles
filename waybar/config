{
    // Bar layer and position
    "layer": "top",
    "position": "top",

    // Modules
    "modules-left": ["wlr/workspaces", "hyprland/submap", "hyprland/window"],
    "modules-center": ["mpd", "custom/media"],
    // "modules-center": ["mpd", mpris"],
    "modules-right": ["cpu", "memory", "pulseaudio", "battery", "network", "clock", "tray"],

    // Workspaces
    "wlr/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "sort-by-number": true,
    },

    // Hyprland submap
    "hyprland/submap": {
        "format": "{}",
        "tooltip": false,
    },
    
    // Window title
    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "separate-outputs": true,
    },

    // Mpd
    "mpd": {
        "interval": 2,

        // Format
        "format": "{stateIcon} {elapsedTime:%M:%S}/{totalTime:%M:%S} {filename}",
        "format-disconnected": "",
        "format-stopped": "󰓛",
        "state-icons": {
            "paused": "󰏤",
            "playing": "󰐊"
        },
        "unknown-tag": "N/A",

        "tooltip": false,
    },

    // MPRIS controller
    "mpris": {
        "interval": 2,

        // Format
        "format": "{status_icon} {dynamic}",
        "format-paused": "{status_icon} {dynamic}",
        "status-icons": {
            "playing": "󰐊",
            "paused": "󰏤",
            "stopped": "󰓛",
        },

        "ignored-players": [],
    },

    // Custom MPRIS controller
    "custom/media": {
        "format": "{icon} {}",
        "format-icons": {
            "Playing": "󰐊",
            "Paused": "󰏤",
        },
        "return-type": "json",

        "exec": "playerctl -a metadata --format '{\"text\": \"{{artist}} - {{markup_escape(title)}}\", \"tooltip\": \"{{playerName}}: {{artist}} - {{album}} - {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' --follow",
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
    },

    // CPU
    "cpu": {
        "interval": 5,

        "format": "󰻠 {usage}%",

        "tooltip": false,
    },

    // Memory
    "memory": {
        "interval": 5,

        "format": "󰍛 {percentage}%",
        "format-alt": "󰍛 {used} GiB",

        "tooltip": false,
    },

    // Pulseaudio
    "pulseaudio": {
        // Format
        "format": "{icon} {volume}%  {format_source}",
        "format-muted": "󰝟 {format_source}",
        "format-icons": {
            "headphone": "󰋋",
            "headset": "󰋎",
            "default": ["󰕿", "󰖀", "󰕾"]
        },

        // Format bluetooth
        "format-bluetooth": "{icon}󰂰 {volume}%  {format_source}",
        "format-bluetooth-muted": "󰝟󰂰 {format_source}",

        // Format source
        "format-source": "󰍬",
        "format-source-muted": "󰍭",

        // Volume control
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    },

    // Battery
    "battery": {
        "interval": 5,

        // Battery states
        "full-at": 97,
        "states": {
            "warning": 30,
            "critical": 15
        },

        // Format
        "format": "{icon}  {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "format-charging": "󰚥 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",

        "tooltip-format": "{time}",
    },

    // Network
    "network": {
        // Format
        "format-wifi": "󰖩 {essid}",
        "format-ethernet": "{ipaddr}",
        "format-disconnected": "󱛅",

        "tooltip-format": "{ifname}: {ipaddr}",
    },

    // Clock
    "clock": {
        "interval": 1,

        // Format
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d %a %H:%M:%S}",

        "tooltip-format": "<tt><small>{calendar}</small></tt>",

        // Calendar
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "left",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },

        // Actions
        "actions":  {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        },
    },

    // Tray
    "tray": {
        "icon-size": 14,
        "spacing": 5,
    },
}

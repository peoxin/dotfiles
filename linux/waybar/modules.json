{
  // Workspaces
  "wlr/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "sort-by-number": true
  },

  // Hyprland workspaces
  "hyprland/workspaces": {
    "format": "{id}"
  },

  // Hyprland submap
  "hyprland/submap": {
    "format": "{}",
    "tooltip": false
  },

  // MPRIS controller
  "mpris": {
    "interval": 2,

    "format": "{status_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "status-icons": {
      "playing": "ůįźä",
      "paused": "ůįŹ§",
      "stopped": "ůįďõ"
    },

    "ignored-players": []
  },

  // CPU
  "cpu": {
    "interval": 5,

    "format": "ůįĽ† {usage}%",

    "tooltip": false
  },

  // Memory
  "memory": {
    "interval": 5,

    "format": "ůįćõ {percentage}%",
    "format-alt": "ůįćõ {used} GiB",

    "tooltip": false
  },

  // Pulseaudio
  "pulseaudio": {
    // Format
    "format": "{icon} {volume}%  {format_source}",
    "format-muted": "ůįĚü {format_source}",
    "format-icons": {
      "headphone": "ůįčč",
      "headset": "ůįčé",
      "default": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"]
    },

    // Format bluetooth
    "format-bluetooth": "{icon}ůįāį {volume}%  {format_source}",
    "format-bluetooth-muted": "ůįĚüůįāį {format_source}",

    // Format source
    "format-source": "ůįć¨",
    "format-source-muted": "ůįć≠",

    // Volume control
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle"
  },

  // Battery
  "battery": {
    "interval": 5,

    // Battery states
    "full-at": 97,
    "states": {
      "warning": 30,
      "critical": 15
    },

    // Format
    "format": "{icon}  {capacity}%",
    "format-icons": ["ÔČĄ", "ÔČÉ", "ÔČā", "ÔČĀ", "ÔČÄ"],
    "format-charging": "ůįö• {capacity}%",
    "format-plugged": "ůįö• {capacity}%",

    "tooltip-format": "{time}"
  },

  // Network
  "network": {
    // Format
    "format-wifi": "ůįĖ© {essid}",
    "format-ethernet": "{ipaddr}",
    "format-disconnected": "ůĪõÖ",

    "tooltip-format": "{ifname}: {ipaddr}",

    "on-click": "networkmanager_dmenu"
  },

  // Clock
  "clock": {
    "interval": 1,

    // Format
    "format": "{:%H:%M}",
    "format-alt": "{:%Y-%m-%d %a %H:%M:%S}",

    "tooltip-format": "<tt><small>{calendar}</small></tt>",

    // Calendar
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "left",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },

    // Actions
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  // Tray
  "tray": {
    "icon-size": 14,
    "spacing": 5
  }
}
